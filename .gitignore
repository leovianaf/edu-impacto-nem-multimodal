# Environment and settings files to ignore
venv/
.venv/
*settings.json
.vscode/
__pycache__/
*.pyc

# Local data files, database outputs and logs
*.csv
*.csv.gz
*.parquet
*.zip
*.xlsx
*.duckdb
*.duckdb.wal
logs/

# Data folders
data/raw/*
data/processed/*
data/interim/*
!data/raw/.gitkeep
!seeds/*
!docs/*

# DBT build and dependencies folders
target/
dbt_packages/
dbt_modules/
